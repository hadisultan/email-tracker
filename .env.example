# =============================================================================
# email-tracker — environment variables
# =============================================================================
# Copy to `.env` for local dev, configure in Netlify UI for production.
# Living-doc rule (per Unit 1 plan): every later unit that introduces a new env
# var must amend BOTH this file AND the README "Environment" section in the
# same PR. Enforce in code review.
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# From the Supabase project dashboard → Project Settings → API.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Direct Postgres connection string (Project Settings → Database → Connection
# string → URI). Used only by the Gmail poller for its advisory-lock
# transaction; other functions use @supabase/supabase-js.
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# --- Google OAuth (for Gmail History API) ------------------------------------
# From Google Cloud Console → APIs & Services → Credentials.
# OAuth client must be in "In production" consent mode (NOT "Testing") to
# avoid the 7-day refresh-token expiry.
GMAIL_OAUTH_CLIENT_ID=<client-id>.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=<client-secret>
# Comma-separated list of email addresses allowed to sign in to the dashboard.
OWNER_EMAIL_ALLOWLIST=you@example.com

# --- Web Push (VAPID) --------------------------------------------------------
# Generate once with: npx web-push generate-vapid-keys
# Rotating these invalidates ALL existing push subscriptions silently;
# every device must re-subscribe via the dashboard.
VAPID_PUBLIC_KEY=<base64url-public-key>
VAPID_PRIVATE_KEY=<base64url-private-key>
VAPID_CONTACT=mailto:you@example.com

# --- Polling driver (cron-job.org) -------------------------------------------
# Shared secret used to authenticate cron-job.org's POSTs to /api/gmail-poll.
# Compute the X-Signature header once over an empty body and store it as a
# custom request header in the cron-job.org job config.
POLL_HMAC_SECRET=<random-32-byte-hex>

# --- Origins (CORS) ----------------------------------------------------------
# DASHBOARD_ORIGIN is the deployed Netlify origin (or http://localhost:5173 in
# local dev). EXTENSION_ORIGIN is chrome-extension://<EXTENSION_ID> — the
# extension uses a stable ID via the manifest.json `key` field (set in U6a).
DASHBOARD_ORIGIN=http://localhost:5173
EXTENSION_ORIGIN=chrome-extension://<extension-id>
SITE_URL=http://localhost:8888
